begin;

-- =========================================================
-- Private authorization helpers
-- =========================================================

create schema if not exists private;

revoke all on schema private from public;
grant usage on schema private to authenticated;

-- Returns true when the current authenticated user owns the map.
create or replace function private.is_map_owner(target_map_id uuid)
returns boolean
language sql
stable
security definer
set search_path = ''
as $$
  select exists (
    select 1
    from public.travel_maps tm
    where tm.id = target_map_id
      and tm.owner_id = (select auth.uid())
  );
$$;

-- Returns true when the current authenticated user can view the map.
create or replace function private.can_view_map(target_map_id uuid)
returns boolean
language sql
stable
security definer
set search_path = ''
as $$
  select
    exists (
      select 1
      from public.travel_maps tm
      where tm.id = target_map_id
        and tm.owner_id = (select auth.uid())
    )
    or exists (
      select 1
      from public.map_members mm
      where mm.map_id = target_map_id
        and mm.user_id = (select auth.uid())
    );
$$;

-- Returns true for map owners and editors.
create or replace function private.can_edit_map(target_map_id uuid)
returns boolean
language sql
stable
security definer
set search_path = ''
as $$
  select
    exists (
      select 1
      from public.travel_maps tm
      where tm.id = target_map_id
        and tm.owner_id = (select auth.uid())
    )
    or exists (
      select 1
      from public.map_members mm
      where mm.map_id = target_map_id
        and mm.user_id = (select auth.uid())
        and mm.role in ('owner', 'editor')
    );
$$;

-- Resolves a trip to its parent travel map.
create or replace function private.trip_map_id(target_trip_id uuid)
returns uuid
language sql
stable
security definer
set search_path = ''
as $$
  select t.map_id
  from public.trips t
  where t.id = target_trip_id;
$$;

grant execute on function private.is_map_owner(uuid) to authenticated;
grant execute on function private.can_view_map(uuid) to authenticated;
grant execute on function private.can_edit_map(uuid) to authenticated;
grant execute on function private.trip_map_id(uuid) to authenticated;

-- =========================================================
-- Enable RLS explicitly
-- The Supabase popup may already have enabled it, but these
-- statements ensure the migration records the intended state.
-- =========================================================

alter table public.profiles enable row level security;
alter table public.travel_maps enable row level security;
alter table public.map_members enable row level security;
alter table public.hoppers enable row level security;
alter table public.locations enable row level security;
alter table public.trips enable row level security;
alter table public.trip_legs enable row level security;
alter table public.trip_hoppers enable row level security;
alter table public.user_preferences enable row level security;

-- =========================================================
-- API privileges
-- RLS policies still determine which rows can be accessed.
-- =========================================================

revoke all on table public.profiles from anon;
revoke all on table public.travel_maps from anon;
revoke all on table public.map_members from anon;
revoke all on table public.hoppers from anon;
revoke all on table public.locations from anon;
revoke all on table public.trips from anon;
revoke all on table public.trip_legs from anon;
revoke all on table public.trip_hoppers from anon;
revoke all on table public.user_preferences from anon;

grant select, insert, update on table public.profiles to authenticated;
grant select, insert, update, delete on table public.travel_maps to authenticated;
grant select, insert, update, delete on table public.map_members to authenticated;
grant select, insert, update, delete on table public.hoppers to authenticated;
grant select on table public.locations to authenticated;
grant select, insert, update, delete on table public.trips to authenticated;
grant select, insert, update, delete on table public.trip_legs to authenticated;
grant select, insert, update, delete on table public.trip_hoppers to authenticated;
grant select, insert, update on table public.user_preferences to authenticated;

