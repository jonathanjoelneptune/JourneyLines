-- =========================================================
-- Cross-map integrity
--
-- Prevent a trip from being associated with a Hopper that
-- belongs to a different travel map.
-- =========================================================

create or replace function public.validate_trip_hopper_map()
returns trigger
language plpgsql
set search_path = ''
as $$
declare
  trip_map uuid;
  hopper_map uuid;
begin
  select t.map_id
  into trip_map
  from public.trips t
  where t.id = new.trip_id;

  select h.map_id
  into hopper_map
  from public.hoppers h
  where h.id = new.hopper_id;

  if trip_map is null then
    raise exception 'The selected trip does not exist.';
  end if;

  if hopper_map is null then
    raise exception 'The selected Hopper does not exist.';
  end if;

  if trip_map <> hopper_map then
    raise exception
      'A trip and Hopper must belong to the same travel map.';
  end if;

  return new;
end;
$$;

create trigger trip_hoppers_validate_map
before insert or update
on public.trip_hoppers
for each row
execute function public.validate_trip_hopper_map();

-- =========================================================
-- Default-map integrity
--
-- A user's default map must be a map they own or belong to.
-- =========================================================

create or replace function public.validate_user_default_map()
returns trigger
language plpgsql
set search_path = ''
as $$
begin
  if new.default_map_id is null then
    return new;
  end if;

  if not exists (
    select 1
    from public.travel_maps tm
    where tm.id = new.default_map_id
      and tm.owner_id = new.user_id
  )
  and not exists (
    select 1
    from public.map_members mm
    where mm.map_id = new.default_map_id
      and mm.user_id = new.user_id
  ) then
    raise exception
      'The default map must be accessible to the user.';
  end if;

  return new;
end;
$$;

create trigger user_preferences_validate_default_map
before insert or update of default_map_id, user_id
on public.user_preferences
for each row
execute function public.validate_user_default_map();

-- =========================================================
-- Automatically create a public profile for new Auth users
-- =========================================================

create or replace function public.handle_new_user()
returns trigger
language plpgsql
security definer
set search_path = ''
as $$
begin
  insert into public.profiles (
    id,
    display_name
  )
  values (
    new.id,
    coalesce(
      nullif(new.raw_user_meta_data ->> 'display_name', ''),
      nullif(new.raw_user_meta_data ->> 'full_name', ''),
      split_part(coalesce(new.email, ''), '@', 1)
    )
  )
  on conflict (id) do nothing;

  return new;
end;
$$;

create trigger on_auth_user_created
after insert on auth.users
for each row
execute function public.handle_new_user();

-- Add profiles for Auth users who already existed before this migration.
insert into public.profiles (
  id,
  display_name
)
select
  au.id,
  coalesce(
    nullif(au.raw_user_meta_data ->> 'display_name', ''),
    nullif(au.raw_user_meta_data ->> 'full_name', ''),
    split_part(coalesce(au.email, ''), '@', 1)
  )
from auth.users au
on conflict (id) do nothing;

commit;
